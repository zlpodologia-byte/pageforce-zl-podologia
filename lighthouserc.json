{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3001/",
        "http://localhost:3001/work",
        "http://localhost:3001/contact"
      ],
      "numberOfRuns": 2,
      "startServerCommand": "npm start",
      "startServerReadyPattern": "Ready"
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.85
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.95
          }
        ]
      }
    }
  }
}
